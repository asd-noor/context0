{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "notebooklm": {
            "enabled": true,
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "notebooklm-mcp-cli",
                "notebooklm-mcp"
            ]
        },
        "projectcontext": {
            "enabled": false,
            "type": "local",
            "command": [
                "uv",
                "run",
                "projectcontext"
            ]
        },
        "codemap": {
            "enabled": false,
            "type": "local",
            "command": [
                "/Users/noor/.local/bin/codemap"
            ],
        },
    }
}
